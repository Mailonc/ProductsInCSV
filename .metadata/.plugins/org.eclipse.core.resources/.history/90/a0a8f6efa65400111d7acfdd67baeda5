package Application;

import java.io.BufferedReader;
import java.io.BufferedWriter;
import java.nio.file.Files;
import java.nio.file.Path;

import entities.Product;

public class Program {

	public static void main(String[] args) {

		Path sourcePath = Path.of("/home/cesar/temp/source.csv");

		Path sourceFolder = sourcePath.getParent();

		Path outFolder = sourceFolder.resolve("out");

		Path summaryFile = outFolder.resolve("summary.csv");

		try {
			Files.createDirectories(outFolder);

			try (BufferedReader br = Files.newBufferedReader(sourcePath);
					BufferedWriter bw = Files.newBufferedWriter(summaryFile)) {
				String line;

				while ((line = br.readLine()) != null) {
					String[] fields = line.split(",");

					String name = fields[0];
					double price = Double.parseDouble(fields[1]);
					int quantity = Integer.parseInt(fields[2]);

					Product product = new Product(name, price, quantity);

					bw.write(product.getName() + "," + String.format("%.2f", product.total())

					);
					bw.newLine();
				}

				System.out.println("Arquivo summary.csv criado com sucesso!");

			}

		} catch (Exception e) {
			System.out.println("Error: " + e.getMessage());
		}
	}

}
